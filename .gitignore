# =============================================================================
# Robot Savo — .gitignore (Savo_Pi workspace)
#
# Track source code, configs, launch files, systemd units, docs, and scripts.
# Ignore generated builds, runtime logs, models, rosbags, caches, and secrets.
# =============================================================================

# -----------------------------------------------------------------------------
# Python bytecode / cache
# -----------------------------------------------------------------------------
__pycache__/
*.py[cod]
*$py.class

# Virtual environments
.venv/
venv/
env/

# Python tooling caches
.mypy_cache/
.pytest_cache/
.coverage
htmlcov/

# -----------------------------------------------------------------------------
# ROS 2 / colcon build artifacts
# -----------------------------------------------------------------------------
build/
install/
log/

# Separate overlays
build_*/
install_*/
log_*/

# -----------------------------------------------------------------------------
# Runtime data / rosbags / logs
# -----------------------------------------------------------------------------
bags/
bags/**/metadata.yaml

*.db3
*.mcap

# Diagnostic/runtime data
*.csv
*.npz
*.npy

# -----------------------------------------------------------------------------
# Models
# -----------------------------------------------------------------------------
models/piper/*.onnx
models/piper/*.onnx.json
models/piper/*.onnx.yaml

models/whisper/
models/llm/
models/checkpoints/

# -----------------------------------------------------------------------------
# Editor / IDE / OS files
# -----------------------------------------------------------------------------
.vscode/
.idea/
*.iml

.DS_Store
Thumbs.db
Desktop.ini

# -----------------------------------------------------------------------------
# AI assistant / local agent tool folders
# -----------------------------------------------------------------------------
.agents/
.claude/
.codex/
.pylibs/

# -----------------------------------------------------------------------------
# Generated archives
# -----------------------------------------------------------------------------
*.zip

# -----------------------------------------------------------------------------
# Temporary files
# -----------------------------------------------------------------------------
*~
*.swp
*.swo
*.tmp
*.bak

# -----------------------------------------------------------------------------
# Local environment / secrets
# -----------------------------------------------------------------------------
.env
.env.*
!.env.example

*.secret
*.key

tools/scripts/env_llm.sh
tools/scripts/env_robot_server.sh

# -----------------------------------------------------------------------------
# Docker / container cache
# -----------------------------------------------------------------------------
.cache/