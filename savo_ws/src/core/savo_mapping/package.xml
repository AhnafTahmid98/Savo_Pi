<?xml version="1.0"?>
<?xml-model href="http://download.ros.org/schema/package_format3.xsd" schematypens="http://www.w3.org/2001/XMLSchema"?>
<package format="3">
  <name>savo_mapping</name>
  <version>0.1.0</version>

  <description>
    Robot Savo core-side mapping workflow package. This package owns map creation,
    mapping supervision, manual mapping workflow, autonomous mapping coordination,
    360 scan mapping, frontier and coverage mapping strategies, map quality checks,
    semantic landmark recording, RealSense mapping-data monitoring, and saved-map
    handoff preparation for navigation.
  </description>

  <maintainer email="tahmidahnaf998@gmail.com">Ahnaf Tahmid</maintainer>
  <license>Proprietary</license>

  <buildtool_depend>ament_cmake</buildtool_depend>

  <depend>rclcpp</depend>
  <depend>std_msgs</depend>
  <depend>geometry_msgs</depend>
  <depend>sensor_msgs</depend>
  <depend>nav_msgs</depend>
  <depend>builtin_interfaces</depend>
  <depend>tf2</depend>
  <depend>tf2_ros</depend>
  <depend>tf2_geometry_msgs</depend>

  <exec_depend>launch</exec_depend>
  <exec_depend>launch_ros</exec_depend>
  <depend>slam_toolbox</depend>

  <test_depend>ament_lint_auto</test_depend>
  <test_depend>ament_lint_common</test_depend>
  <test_depend>ament_cmake_gtest</test_depend>

  <export>
    <build_type>ament_cmake</build_type>
  </export>
  <depend>lifecycle_msgs</depend>
  <depend>std_srvs</depend>
  <depend>yaml_cpp_vendor</depend>
  <depend>nav2_map_server</depend>
  <depend>openssl</depend>
  <depend>nav2_msgs</depend>
  <depend>rclcpp_action</depend>
</package>
