<?xml version="1.0" encoding="UTF-8"?>

<launch>

  <arg
    name="map_id"
    default="phase4e_room"/>

  <arg
    name="map_output_root"
    default="/tmp/savo_mapping_phase4e"/>

  <arg
    name="allow_map_overwrite"
    default="false"/>

  <include
    file="$(find-pkg-share savo_mapping)/launch/manual_mapping.launch.xml">

    <arg
      name="use_sim_time"
      value="false"/>

    <arg
      name="autostart"
      value="true"/>

    <arg
      name="slam_params_file"
      value="$(find-pkg-share savo_mapping)/config/slam_toolbox_mapping.yaml"/>

    <arg
      name="map_id"
      value="$(var map_id)"/>

    <arg
      name="map_output_root"
      value="$(var map_output_root)"/>

    <arg
      name="allow_map_overwrite"
      value="$(var allow_map_overwrite)"/>
  </include>

  <node
    pkg="savo_mapping"
    exec="simulated_slam_input_node"
    name="simulated_slam_input_node"
    output="screen">

    <param
      from="$(find-pkg-share savo_mapping)/config/profiles/simulated_slam.yaml"/>

    <param
      name="use_sim_time"
      value="false"/>
  </node>
</launch>
