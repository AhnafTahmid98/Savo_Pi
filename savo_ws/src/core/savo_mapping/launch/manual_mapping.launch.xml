<?xml version="1.0" encoding="UTF-8"?>

<launch>

  <arg
    name="map_id"
    default=""
    description="Stable lowercase map identifier"/>

  <arg
    name="map_output_root"
    default="~/Savo_Pi/runtime/maps"
    description="Root directory for map sessions"/>

  <arg
    name="allow_map_overwrite"
    default="false"/>

  <arg
    name="use_sim_time"
    default="false"
    description="Use the ROS simulation clock"/>

  <arg
    name="autostart"
    default="true"
    description="Configure and activate slam_toolbox automatically"/>

  <arg
    name="slam_params_file"
    default="$(find-pkg-share savo_mapping)/config/slam_toolbox_mapping.yaml"
    description="Full path to the slam_toolbox mapping parameters"/>

  <node
    pkg="savo_mapping"
    exec="mapping_supervisor_node"
    name="mapping_supervisor_node"
    output="screen">

    <param
      from="$(find-pkg-share savo_mapping)/config/topics.yaml"/>

    <param
      from="$(find-pkg-share savo_mapping)/config/frames.yaml"/>

    <param
      from="$(find-pkg-share savo_mapping)/config/mapping_common.yaml"/>

    <param
      from="$(find-pkg-share savo_mapping)/config/map_session.yaml"/>

    <param
      from="$(find-pkg-share savo_mapping)/config/profiles/manual_mapping.yaml"/>

    <param
      name="use_sim_time"
      value="$(var use_sim_time)"/>
  </node>

  <include
    file="$(find-pkg-share slam_toolbox)/launch/online_async_launch.py">

    <arg
      name="slam_params_file"
      value="$(var slam_params_file)"/>

    <arg
      name="use_sim_time"
      value="$(var use_sim_time)"/>

    <arg
      name="autostart"
      value="$(var autostart)"/>

    <arg
      name="use_lifecycle_manager"
      value="false"/>
  </include>

  <node
    pkg="savo_mapping"
    exec="slam_lifecycle_health_bridge_node"
    name="slam_lifecycle_health_bridge_node"
    output="screen">

    <param
      from="$(find-pkg-share savo_mapping)/config/slam_lifecycle_health.yaml"/>

    <param
      name="use_sim_time"
      value="$(var use_sim_time)"/>
  </node>


  <include
    file="$(find-pkg-share savo_mapping)/launch/map_session_manager.launch.xml">

    <arg
      name="map_id"
      value="$(var map_id)"/>

    <arg
      name="map_output_root"
      value="$(var map_output_root)"/>

    <arg
      name="allow_map_overwrite"
      value="$(var allow_map_overwrite)"/>

    <arg
      name="use_sim_time"
      value="$(var use_sim_time)"/>
  </include>

</launch>
