<launch>
  <arg
    name="params_file"
    default="$(find-pkg-share savo_mapping)/config/exploration_goal_handoff.yaml"/>

  <arg
    name="expected_frame"
    default="map"/>

  <arg
    name="server_wait_timeout_sec"
    default="3.0"/>

  <arg
    name="goal_response_timeout_sec"
    default="3.0"/>

  <arg
    name="execution_timeout_sec"
    default="300.0"/>

  <arg
    name="feedback_stale_timeout_sec"
    default="10.0"/>

  <arg
    name="cancel_timeout_sec"
    default="5.0"/>

  <node
    pkg="savo_mapping"
    exec="exploration_goal_handoff_node"
    name="exploration_goal_handoff_node"
    output="screen">

    <param from="$(var params_file)"/>

    <param
      name="expected_frame"
      value="$(var expected_frame)"/>

    <param
      name="server_wait_timeout_sec"
      value="$(var server_wait_timeout_sec)"/>

    <param
      name="goal_response_timeout_sec"
      value="$(var goal_response_timeout_sec)"/>

    <param
      name="execution_timeout_sec"
      value="$(var execution_timeout_sec)"/>

    <param
      name="feedback_stale_timeout_sec"
      value="$(var feedback_stale_timeout_sec)"/>

    <param
      name="cancel_timeout_sec"
      value="$(var cancel_timeout_sec)"/>
  </node>
</launch>
