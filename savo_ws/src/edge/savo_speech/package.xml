<?xml version="1.0"?>
<?xml-model
  href="http://download.ros.org/schema/package_format3.xsd"
  schematypens="http://www.w3.org/2001/XMLSchema"?>

<package format="3">
  <name>savo_speech</name>
  <version>0.1.0</version>

  <description>
    Robot Savo physical speech-interface package. It owns ReSpeaker
    microphone capture and playback, wake-word detection, voice activity
    detection, utterance recording, audio transport to SavoMind,
    microphone gating, playback completion, speech runtime state,
    health monitoring, and diagnostics.
  </description>

  <maintainer email="tahmidahnaf998@gmail.com">
    Ahnaf Tahmid
  </maintainer>

  <license>Proprietary</license>

  <buildtool_depend>ament_cmake</buildtool_depend>

  <depend>rclcpp</depend>
  <depend>std_msgs</depend>
  <depend>diagnostic_msgs</depend>

  <build_depend>libasound2-dev</build_depend>
  <exec_depend>libasound2</exec_depend>

  <exec_depend>launch</exec_depend>
  <exec_depend>launch_ros</exec_depend>

  <test_depend>ament_cmake_gtest</test_depend>
  <test_depend>ament_lint_auto</test_depend>
  <test_depend>ament_lint_common</test_depend>

  <export>
    <build_type>ament_cmake</build_type>
  </export>
</package>
